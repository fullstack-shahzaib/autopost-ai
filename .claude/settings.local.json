{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(git init)",
      "Bash(git switch:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "fp=$(jq -r '.tool_input.file_path'); case \"$fp\" in *.ts|*.tsx) npx prettier --write \"$fp\" ;; esac"
          }
        ]
      }
    ]
  }
}